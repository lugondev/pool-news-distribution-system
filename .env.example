# ─── Local services ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SQLITE_PATH=./data/stats.db
APP_PORT=8000

# ─── CORS — for split frontend (Vercel UI ↔ Coolify backend) ─────────────────
# Comma-separated list of origins that may call the API from a browser.
# Empty = no CORS headers (same-origin only, e.g. when serving the Jinja UI).
# Examples:
#   CORS_ALLOW_ORIGINS=https://news.example.com
#   CORS_ALLOW_ORIGINS=https://news.example.com,https://*.vercel.app
CORS_ALLOW_ORIGINS=

# AI config (api_key, base_url, model) is managed in Settings UI → config/settings.yaml

# ─── Vector DB (Weaviate) — only needed when running with --profile rag ──────
WEAVIATE_HOST=weaviate
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# ─── Backup / Migration: Litestream → S3-compatible ──────────────────────────
# Leave LITESTREAM_BUCKET empty to disable replication (single-host / dev).
# When set, SQLite is continuously replicated AND auto-restored on cold boot.
#
# Cloudflare R2 example (project already has account_id in settings.yaml):
#   LITESTREAM_BUCKET=news-aggregator-backups
#   LITESTREAM_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#   LITESTREAM_REGION=auto
#   LITESTREAM_ACCESS_KEY_ID=<r2 access key>
#   LITESTREAM_SECRET_ACCESS_KEY=<r2 secret>
#
# AWS S3 example:
#   LITESTREAM_BUCKET=my-backups
#   LITESTREAM_ENDPOINT=        # leave empty for AWS
#   LITESTREAM_REGION=us-east-1
LITESTREAM_BUCKET=
LITESTREAM_PATH=news-aggregator/sqlite
LITESTREAM_ENDPOINT=
LITESTREAM_REGION=auto
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# ─── Redis backup sidecar ────────────────────────────────────────────────────
# Uses the same S3 credentials as Litestream (above). Tune cadence/retention:
REDIS_BACKUP_INTERVAL_SECONDS=3600   # snapshot every hour
REDIS_BACKUP_RETENTION_DAYS=7        # keep 7 days of snapshots
REDIS_BACKUP_PREFIX=news-aggregator/redis

# ─── Config backend (YAML files vs Supabase Postgres) ────────────────────────
# CONFIG_BACKEND chooses the storage layer for sources/settings/agents/personas.
# 117+ call sites in the codebase use the same API regardless — only this var
# decides where the bytes actually live.
#
#   yaml   Default. App reads/writes config/*.yaml in the `app-config` volume.
#          Settings UI saves persist to YAML files. No external dependency.
#
#   db     App reads/writes 4 Postgres tables (sources, social_agents,
#          sim_personas, settings) in Supabase. Settings UI saves go straight
#          to DB. Multi-host deploys share one canonical config in real time.
#          Reads cached for 30s to keep DB load low.
#          Requires SUPABASE_DB_URL + tables initialized via
#          `python config/sync.py init && python config/sync.py yaml-to-db`.
#
# In `db` mode the entrypoint runs a fast Supabase reachability check before
# the app starts; if it fails, the container exits — no silent degradation.
CONFIG_BACKEND=yaml

# Used by both `CONFIG_BACKEND=db` and the manual `config/sync.py` CLI.
# Get the URI from Supabase → Settings → Database → "Connection string" →
# URI tab → "Transaction" mode (Pooler, IPv4, port 6543).
#
# Special chars in password MUST be URL-encoded (! → %21, @ → %40, # → %23).
# Example:
#   SUPABASE_DB_URL=postgresql://postgres.<ref>:<encoded-pass>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_URL=
